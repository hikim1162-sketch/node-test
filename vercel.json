{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm --prefix netlify-private-app install",
  "buildCommand": "npm --prefix netlify-private-app run build",
  "outputDirectory": "netlify-private-app/dist",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
