{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd netlify-private-app && npm ci",
  "buildCommand": "cd netlify-private-app && npm run build",
  "outputDirectory": "netlify-private-app/dist",
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/(?!api(?:/|$)).*$", "dest": "/index.html" }
  ]
}
